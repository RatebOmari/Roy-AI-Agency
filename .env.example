# Backend API URL — no trailing slash, must end with /api
#
# Option A: Local Node.js backend (run `cd backend && npm run dev` first)
#   VITE_API_URL=http://localhost:3001/api
#
# Option B: Production (Railway / any host)
#   VITE_API_URL=https://your-app.railway.app/api
#
# Leave empty for fully mocked demo mode (no backend needed)
VITE_API_URL=

# Optional: App name override
VITE_APP_NAME=SocialPilot
