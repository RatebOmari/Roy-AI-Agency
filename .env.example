# Backend URL — no trailing slash, must include /webhook path
#
# Option A: n8n (legacy)
#   VITE_N8N_WEBHOOK_URL=https://n8n.srv1700245.hstgr.cloud/webhook
#
# Option B: Node.js backend (local dev — run `cd backend && npm run dev` first)
#   VITE_N8N_WEBHOOK_URL=http://localhost:3001/webhook
#
# Option C: Node.js backend (Railway/production)
#   VITE_N8N_WEBHOOK_URL=https://your-app.railway.app/webhook
#
# Leave empty to use fully mocked demo mode (no backend needed)
VITE_N8N_WEBHOOK_URL=

# Optional: App name override
VITE_APP_NAME=SocialPilot
