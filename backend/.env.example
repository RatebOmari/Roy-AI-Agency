# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (from Supabase, Railway, or any Postgres host)
DATABASE_URL=postgresql://user:password@host:5432/socialpilot
# Connection pool size (default 20)
DB_POOL_SIZE=20

# ── Authentication ─────────────────────────────────────────────────────────────
# Secret for signing JWTs — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-here

# AES-256-GCM key for encrypting platform credentials at rest — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes). Omit in dev to store plaintext.
ENCRYPTION_KEY=

# ── AI ─────────────────────────────────────────────────────────────────────────
# Anthropic API key for AI reply generation
ANTHROPIC_API_KEY=
# OpenAI API key (fallback / image generation)
OPENAI_API_KEY=

# ── Email ──────────────────────────────────────────────────────────────────────
# Resend API key for sending team invite emails (optional — falls back to console log)
RESEND_API_KEY=
# Sending domain for Resend (must be verified in Resend dashboard)
EMAIL_FROM_DOMAIN=socialpilot.app

# ── Twilio (SMS / Calls) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── WhatsApp Business ──────────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_wa_phone_number_id

# ── Meta / Facebook / Instagram ────────────────────────────────────────────────
META_APP_SECRET=your_meta_app_secret

# ── TikTok ─────────────────────────────────────────────────────────────────────
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# ── Webhook ────────────────────────────────────────────────────────────────────
# Meta webhook verification token (matches what you enter in Meta Developer Console)
WEBHOOK_VERIFY_TOKEN=your_meta_webhook_verify_token

# ── Monitoring ─────────────────────────────────────────────────────────────────
# Sentry DSN for backend error tracking (leave empty to disable)
SENTRY_DSN=
# Sentry org/project/auth token for uploading source maps at build time
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Server ─────────────────────────────────────────────────────────────────────
# Frontend URL — used to construct invite links in emails
APP_URL=http://localhost:5174
# Port (Railway sets this automatically)
PORT=3001
# Frontend URL for CORS (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.railway.app
# Log level for pino: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info
