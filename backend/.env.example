# PostgreSQL connection string (from Supabase or any Postgres host)
DATABASE_URL=postgresql://user:password@host:5432/socialpilot

# Secret for signing JWTs — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-here

# AES-256-GCM key for encrypting platform credentials at rest — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes). Omit in dev to store plaintext.
ENCRYPTION_KEY=

# Anthropic API key for AI reply generation
ANTHROPIC_API_KEY=

# Frontend URL — used to construct invite links in emails
APP_URL=http://localhost:5174

# Port (Railway sets this automatically)
PORT=3001

# Frontend URL for CORS (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.railway.app

# Resend API key for sending team invite emails (optional — falls back to console log)
RESEND_API_KEY=

# Sending domain for Resend (must be verified in Resend dashboard)
EMAIL_FROM_DOMAIN=socialpilot.app
