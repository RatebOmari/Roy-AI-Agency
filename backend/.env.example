# PostgreSQL connection string (from Supabase or any Postgres host)
DATABASE_URL=postgresql://user:password@host:5432/socialpilot

# Secret for signing JWTs — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-here

# Port (Railway sets this automatically)
PORT=3001

# Frontend URL for CORS (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.railway.app
